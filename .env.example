# ConnectHub Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── API & WebSocket ─────────────────────────────────────────────────
# Previous local defaults (kept for reference):
# VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_WS_URL=http://localhost:8080/ws
# Production (Vercel) - point to the public API Gateway:
VITE_API_BASE_URL=http://YOUR_EC2_IP:8080/api/v1
VITE_WS_URL=http://YOUR_EC2_IP:8080/ws

# ── OAuth2 ─────────────────────────────────────────────────────────
# Base URL for /oauth2/authorization/* redirects to the backend gateway.
VITE_OAUTH_BASE_URL=http://YOUR_EC2_IP:8080

# ── Razorpay ─────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
# The plan ID from your Razorpay dashboard for the PRO subscription
VITE_RAZORPAY_PLAN_ID=plan_XXXXXXXXXXXXXXXXXX

# ── Feature Flags ────────────────────────────────────────────────────
# Set to true to enable PRO features (subscription gate) in the UI
VITE_ENABLE_PAYMENTS=true

# ── Firebase Cloud Messaging (Push Notifications) ────────────────────
# Get these from Firebase Console → Project Settings → General → Your apps
# Leave blank to disable push notifications (the UI will show "not configured")
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VAPID key: Firebase Console → Project Settings → Cloud Messaging → Web configuration
VITE_FIREBASE_VAPID_KEY=
